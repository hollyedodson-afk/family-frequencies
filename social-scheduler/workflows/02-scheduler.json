              "id": "c2",
              "leftValue": "={{ DateTime.fromISO($json.scheduled_at.replace(' ', 'T'), {zone: 'Pacific/Auckland'}).toISO() }}",
              "rightValue": "={{ $now.toISO() }}",
              "operator": { "type": "dateTime", "operation": "before" }
            }
