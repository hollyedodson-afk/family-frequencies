    {
      "parameters": {
        "chatId": "8770824903",
        "text": "=⚠️ *FF Social - Post skipped, no caption*\n\nRow `{{ $json.id }}` was due but has an empty caption so it wasn't posted.\n\n*Media:* {{ $json.media_url }}\n*Scheduled:* {{ $json.scheduled_at }}\n*Type:* {{ $json.type }}\n\nFix the caption in the sheet and set status back to `scheduled`.",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
